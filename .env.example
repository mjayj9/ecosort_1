# -----------------------------------------------------------------------------
# 보안 원칙: Android 앱에는 어떤 AI API 키도 넣지 않는다.
# Gemini API 키는 서버(Cloud Functions) 전용이며 Firebase Secret Manager로 관리한다.
#
#   firebase functions:secrets:set GEMINI_API_KEY
#
# 아래 값들은 로컬 개발 편의를 위한 것으로, 앱 빌드에 필수 아님.
# -----------------------------------------------------------------------------

# (서버 전용, functions/ 로컬 에뮬레이터 실행 시 .env 파일로 주입)
# GEMINI_API_KEY=server-side-only-do-not-put-in-app
# GEMINI_MODEL=gemini-3-flash-preview
